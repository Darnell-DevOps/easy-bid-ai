# Every VITE_ variable is embedded in the browser bundle and must be safe to expose.
# Copy this file to .env.local only when overriding the checked-in public defaults.
VITE_SUPABASE_PROJECT_ID=
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_PAYMENTS_CLIENT_TOKEN=

# Keep server credentials, webhook secrets, salts, and Paddle API keys in
# Lovable Cloud / Supabase Edge Function secrets. Never add them here.
